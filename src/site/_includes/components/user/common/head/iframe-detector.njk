<script>
(function() {
    if (window !== window.top) {
        document.documentElement.classList.add('is-in-iframe');
        console.error("[V2.10 Log] Iframe mode. Synthetic Hover-Scroll Engine ENGAGED.");

        // 监听滚轮，强行接管物理滚动
        window.addEventListener('wheel', function(e) {
            // 获取真正的滚动承载容器 (兼容不同浏览器的标准)
            const scrollTarget = document.scrollingElement || document.body;
            
            if (scrollTarget) {
                scrollTarget.scrollBy({
                    top: e.deltaY,
                    left: e.deltaX,
                    behavior: 'auto' // 保持原生无延迟手感
                });
            }
        }, { passive: true }); // passive 保证不阻塞主线程，顺滑无比
    }
})();
</script>