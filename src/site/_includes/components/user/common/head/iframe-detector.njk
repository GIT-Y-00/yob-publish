<script>
document.addEventListener("DOMContentLoaded", () => {
    // [v1.0 Log] 确认脚本已在客户端加载
    console.log("[v1.0 Log] Iframe Detector initialized. Waiting for Excalidraw...");

    // 使用 MutationObserver 监听动态生成的 Canvas 元素
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
                // 仅处理元素节点
                if (node.nodeType === 1) { 
                    
                    // 寻找潜在的链接节点 (兼容多种可能生成的 DOM 结构)
                    let links = [];
                    if (node.matches && node.matches('.notelink a.filename, a.internal-link')) {
                        links.push(node);
                    } else if (node.querySelectorAll) {
                        const found = node.querySelectorAll('.notelink a.filename, a.internal-link');
                        links = [...links, ...Array.from(found)];
                    }

                    links.forEach(link => {
                        const href = link.getAttribute('href');
                        if (!href || !href.includes('/Vault/')) return;

                        // 关键判断：确保该链接是在 Excalidraw 的势力范围内生成的
                        // 防止误伤页面左侧导航栏或正文的普通链接
                        const isInsideExcalidraw = link.closest('.excalidraw__canvas, .excalidraw-container, [class*="excalidraw"]');
                        if (!isInsideExcalidraw) return;

                        const parentBox = link.parentElement;

                        // 防止重复注入
                        if (parentBox.querySelector('.excalidraw-md-iframe')) return;

                        console.log(`[v1.0 Log] SUCCESS! Upgrading element to iframe: ${href}`);

                        // 创建小网页 iframe
                        const iframe = document.createElement('iframe');
                        iframe.src = href;
                        iframe.className = 'excalidraw-md-iframe';
                        
                        // 隐藏原始链接文本
                        link.style.display = 'none';
                        
                        // 将 iframe 注入 DOM
                        parentBox.appendChild(iframe);
                        parentBox.classList.add('excalidraw-iframe-wrapper');
                    });
                }
            });
        });
    });

    // 监控整个 body 的变化，因为 Excalidraw 是异步渲染的
    observer.observe(document.body, {
        childList: true,
        subtree: true
    });
});
</script>