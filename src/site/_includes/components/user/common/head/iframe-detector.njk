<script>
(function() {
    // 核心判断：当前窗口是否不是最顶层窗口？
    // 如果 window !== window.top，说明当前页面被嵌在 iframe 里
    if (window !== window.top) {
        
        // 立即给最顶层的 HTML 标签打上标记
        document.documentElement.classList.add('is-in-iframe');
        
        // [v2.0 Log] 确认页面已进入“内嵌隐身模式”
        console.log("[v2.0 Log] Self-awareness triggered: I am running inside an iframe. Hiding UI elements.");
    }
})();
</script>