<script>
(function() {
    if (window !== window.top) {
        document.documentElement.classList.add('is-in-iframe');
        console.error("[V2.11 Log] Iframe mode. High-Performance Scroll Engine ENGAGED.");

        const scrollTarget = document.scrollingElement || document.documentElement || document.body;
        
        window.addEventListener('wheel', function(e) {
            // [V2.11 核心修复 1] 拦截并吃掉原生的滚轮事件，防止与父级容器发生“抢夺”
            if (e.cancelable) {
                e.preventDefault();
            }

            // [V2.11 核心修复 2] 弃用会被动画打断的 scrollBy，直接对底层滚动像素属性 (scrollTop) 进行绝对赋值
            // 这保证了鼠标滚几格，像素就精准移动多少，绝不吞输入！
            scrollTarget.scrollTop += e.deltaY;
            scrollTarget.scrollLeft += e.deltaX;

        }, { passive: false }); // 必须是 false 才能使用 preventDefault
    }
})();
</script>