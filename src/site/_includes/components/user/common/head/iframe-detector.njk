<script>
document.addEventListener("DOMContentLoaded", () => {
    console.log("[v1.1 Log] Trojan Iframe Hunter initialized.");

    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
                if (node.nodeType === 1) { 
                    
                    // 收集刚插入 DOM 的所有 iframe
                    let iframes = [];
                    if (node.tagName === 'IFRAME') {
                        iframes.push(node);
                    } else if (node.querySelectorAll) {
                        iframes = [...iframes, ...Array.from(node.querySelectorAll('iframe'))];
                    }

                    iframes.forEach(iframe => {
                        const src = iframe.getAttribute('src');
                        
                        // 只拦截我们伪造的特洛伊木马 URL
                        if (src && src.includes('dg-local-embed.com/Vault/')) {
                            console.log(`[v1.1 Log] Trojan iframe caught: ${src}`);
                            
                            // 砍掉假域名，恢复相对路径，浏览器会自动加上当前的 Cloudflare 域名
                            const realRelativePath = src.replace('https://dg-local-embed.com', '');
                            iframe.setAttribute('src', realRelativePath);
                            
                            // 注入类名以应用我们的自定义 CSS
                            iframe.classList.add('excalidraw-md-iframe');
                            if (iframe.parentElement) {
                                iframe.parentElement.classList.add('excalidraw-iframe-wrapper');
                            }

                            console.log(`[v1.1 Log] Iframe source fixed to: ${realRelativePath}`);
                        }
                    });
                }
            });
        });
    });

    observer.observe(document.body, {
        childList: true,
        subtree: true
    });
});
</script>