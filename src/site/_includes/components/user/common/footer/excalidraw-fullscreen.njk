//src/site/_includes/components/user/common/footer/excalidraw-fullscreen.njk
<script>
document.addEventListener("DOMContentLoaded", () => {
    if (window !== window.top) return;

    const observer = new MutationObserver((mutations) => {
        const wrapper = document.querySelector('.excalidraw-wrapper');
        
        if (wrapper && !wrapper.querySelector('.dg-excalidraw-fs-btn')) {
            console.log("[V4.1 Log] Excalidraw wrapper detected. Injecting Fullscreen SVG toggle.");
            
            const btn = document.createElement('button');
            btn.className = 'dg-excalidraw-fs-btn';
            btn.title = "Toggle Canvas Fullscreen";
            
            // [V4.1 更新] 定义极简线条的 SVG 图标
            const iconExpand = `<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>`;
            const iconClose = `<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`;
            
            // 初始状态为展开图标
            btn.innerHTML = iconExpand; 
            
            btn.addEventListener('pointerdown', (e) => e.stopPropagation());
            
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                
                wrapper.classList.toggle('is-fullscreen');
                const isFs = wrapper.classList.contains('is-fullscreen');
                
                if (isFs) {
                    btn.innerHTML = iconClose; // 切换为 SVG 关闭图标
                    document.body.style.overflow = 'hidden';
                } else {
                    btn.innerHTML = iconExpand; // 切换为 SVG 展开图标
                    document.body.style.overflow = ''; 
                }
                
                window.dispatchEvent(new Event('resize'));
            });
            
            wrapper.appendChild(btn);
        }
    });

    observer.observe(document.body, { childList: true, subtree: true });
});
</script>